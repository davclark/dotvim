[submodule "pathogen"]
	path = pathogen
	url = git://github.com/tpope/vim-pathogen.git
[submodule "bundle/Vim-R-plugin"]
	path = disabled-bundles/Vim-R-plugin
	url = git://github.com/vim-scripts/Vim-R-plugin.git
	ignore = untracked
